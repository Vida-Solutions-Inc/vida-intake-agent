# Optional environment overrides. Most users configure via `intake setup`
# instead of this file; these are here for power users and CI.

# Your Anthropic API key. Preferred storage is the OS keychain (set during
# `intake setup`); this env var overrides it when present.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: use a config file at a non-default location.
# INTAKE_CONFIG=C:\path\to\config.toml
